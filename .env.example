# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Mapbox (required for map features on category pages)
NEXT_PUBLIC_MAPBOXGL_ACCESS_TOKEN=

# Supabase PostgreSQL — Transaction pooler (port 6543, use for the Next.js app)
# Supabase Dashboard → Project Settings → Database → Connection string → URI (Session mode / pooler)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

# Supabase PostgreSQL — Direct connection (port 5432, use for Prisma migrations)
# Supabase Dashboard → Project Settings → Database → Connection string → URI (Direct)
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=

# OAuth providers (optional — only needed if using Google/GitHub sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Email verification (required for credential registration)
RESEND_API_KEY=

# Duffel live flight search — sign up at https://duffel.com (Dashboard → Developers → Access tokens)
# Test tokens start with duffel_test_
DUFFEL_ACCESS_TOKEN=

# Stripe (required for payments and saved cards)
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe webhooks (optional locally — use Stripe CLI: stripe listen --forward-to localhost:3000/api/stripe/webhook)
STRIPE_WEBHOOK_SECRET=
